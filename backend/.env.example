# === Backend ===
# 포트 번호는 전부 deepeye_lite/.env 에서 관리 (CLAUDE.md §12).
# 이 파일은 비-Docker 로컬 실행(poetry run) 시 참조되는 백엔드 전용 설정만 둔다.

# 서버 IP 주소
INTERNAL_IP={내부IP주소입력}
EXTERNAL_IP={외부IP주소입력}

# CORS 허용 origin (* = 모든 origin 허용, 배포 시 제한 필요)
CORS_ORIGINS=*
# JPEG 인코딩 품질 (0~100, 높을수록 고화질/대용량)
JPEG_QUALITY=70
# 최대 웹캠 수
MAX_WEBCAMS=16
# 캡처 FPS 제한 (sleep 간격, 초 단위)
CAPTURE_INTERVAL=0.03
# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# MediaMTX REST API 주소 — 비-Docker 로컬 실행용 기본값.
# Docker 기동 시 compose 의 environment 블록이 http://mediamtx:${MEDIAMTX_API_PORT} 로 override.
MEDIAMTX_API=http://localhost:9997
